<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<BorderPane fx:id="bp" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="800.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="khe.banking.controllers.login.LoginController">
   <center>
      <VBox alignment="CENTER" maxWidth="500.0" spacing="25.0" styleClass="login-container" BorderPane.alignment="CENTER">
         <children>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="WELCOME" textAlignment="CENTER">
               <font>
                  <Font name="Arial Black" size="36.0" />
               </font>
            </Text>
            <TextField fx:id="username" prefHeight="40.0" promptText="Enter username:" />
            <StackPane alignment="CENTER_RIGHT">
               <children>
                  <PasswordField fx:id="pf" prefHeight="40.0" promptText="Enter password:" />
                  <TextField fx:id="tf" prefHeight="40.0" promptText="Enter password:" visible="false" />
                  <ToggleButton fx:id="tg" mnemonicParsing="false" onAction="#tgClicked" styleClass="pw-btn">
                     <graphic>
                        <ImageView fx:id="iv" fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true" />
                     </graphic>
                     <StackPane.margin>
                        <Insets right="5.0" />
                     </StackPane.margin>
                  </ToggleButton>
               </children>
            </StackPane>
            <HBox alignment="CENTER" prefHeight="30.0" spacing="150.0">
               <children>
                  <Hyperlink onAction="#newUser" text="Create New User" />
                  <Hyperlink onAction="#forgotPw" text="Forgot Password" />
               </children>
            </HBox>
            <Button defaultButton="true" mnemonicParsing="false" onAction="#login" prefHeight="40.0" prefWidth="100.0" text="Login" textAlignment="CENTER">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
            </Button>
         </children>
         <padding>
            <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
         </padding>
         <BorderPane.margin>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </BorderPane.margin>
      </VBox>
   </center>
   <padding>
      <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
   </padding>
</BorderPane>

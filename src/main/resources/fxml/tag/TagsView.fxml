<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Accordion?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="780.0" prefWidth="880.0" spacing="25.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="khe.banking.controllers.tag.TagsController">
   <children>
      <Label styleClass="view-title" text="TAGS VIEW" />
      <Accordion fx:id="accordion">
        <panes>
          <TitledPane fx:id="atPane" animated="false" expanded="true" text="Account Types">
               <content>
                  <VBox spacing="10.0">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                           <children>
                              <Button alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" prefHeight="30.0" prefWidth="40.0">
                                 <graphic>
                                    <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                                       <image>
                                          <Image url="@../../img/print.png" />
                                       </image>
                                    </ImageView>
                                 </graphic>
                              </Button>
                              <Button alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" onAction="#newType" prefHeight="30.0" prefWidth="40.0">
                                 <graphic>
                                    <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                                       <image>
                                          <Image url="@../../img/add.png" />
                                       </image>
                                    </ImageView>
                                 </graphic>
                              </Button>
                              <TextField prefHeight="30.0" prefWidth="170.0" promptText="Search..." />
                           </children>
                        </HBox>
                        <TableView fx:id="typeTable">
                          <columns>
                            <TableColumn fx:id="at_idCol" prefWidth="65.0" text="ID" />
                              <TableColumn fx:id="codeCol" prefWidth="100.0" text="Code" />
                            <TableColumn fx:id="at_nameCol" prefWidth="150.0" text="Name" />
                              <TableColumn fx:id="interestCol" prefWidth="100.0" text="Interest Rate" />
                              <TableColumn fx:id="feeCol" prefWidth="100.0" text="Monthly Fee" />
                              <TableColumn fx:id="limitCol" prefWidth="100.0" text="Withdrawal Limit" />
                              <TableColumn fx:id="minCol" prefWidth="100.0" text="Minimum Balance" />
                          </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                     </children>
                  </VBox>
               </content>
            </TitledPane>
          <TitledPane fx:id="cPane" animated="false" text="Categories">
               <content>
                  <VBox spacing="10.0">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                  			<children>
                              <Button alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" prefHeight="30.0" prefWidth="40.0">
                                 <graphic>
                                    <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                                       <image>
                                          <Image url="@../../img/print.png" />
                                       </image>
                                    </ImageView>
                                 </graphic>
                              </Button>
                  				<Button alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" onAction="#newCategory" prefHeight="30.0" prefWidth="40.0">
                  					<graphic>
                  						<ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                  							<image>
                  								<Image url="@../../img/add.png" />
                  							</image>
                  						</ImageView>
                  					</graphic>
                  				</Button>
                  				
                  				
                  				<TextField prefHeight="30.0" prefWidth="170.0" promptText="Search..." />
                  			</children>
                  		</HBox>
                        <TableView fx:id="categoryTable">
                          <columns>
                            <TableColumn fx:id="c_idCol" prefWidth="75.0" text="ID" />
                            <TableColumn fx:id="c_nameCol" prefWidth="150.0" text="Name" />
                              <TableColumn fx:id="c_typeCol" prefWidth="100.0" text="Type" />
                          </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                     </children>
                  </VBox>
               </content>
            </TitledPane>
        </panes>
      </Accordion>      
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>

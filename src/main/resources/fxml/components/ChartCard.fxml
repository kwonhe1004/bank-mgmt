<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="khe.banking.controllers.components.ChartCardController">
   <children>
      <HBox alignment="CENTER_LEFT" spacing="15.0" VBox.vgrow="ALWAYS">
         <children>
            <VBox alignment="CENTER" spacing="5.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label fx:id="titleLabel" styleClass="card-title" text="Monthly Spending" />
                  <Label fx:id="subtitleLabel" styleClass="card-subtitle" text="Last 30 Days" />
               </children>
            </VBox>
         </children>
      </HBox>
      <StackPane fx:id="chartContainer" VBox.vgrow="ALWAYS" />
   </children>
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
</VBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<FlowPane fx:id="root" alignment="CENTER_LEFT" columnHalignment="RIGHT" hgap="10.0" prefWrapLength="500.0" styleClass="filter-pane" vgap="10.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <VBox fx:id="sortBox">
               <children>
                  <Label text="SORT BY" />
                  <ComboBox fx:id="sortFilter" prefHeight="30.0" promptText="SORTING" />
               </children>
            </VBox>
            <VBox fx:id="amountBox">
               <children>
                  <Label text="AMOUNT" />
                  <HBox alignment="CENTER_LEFT" spacing="5.0">
                     <children>
                        <TextField fx:id="fromAmount" prefHeight="30.0" prefWidth="100.0" promptText="\$0.00" />
                        <Label text="-">
                           <font>
                              <Font name="Arial Black" size="14.0" />
                           </font>
                        </Label>
                        <TextField fx:id="toAmount" prefHeight="30.0" prefWidth="100.0" promptText="\$0.00" />
                     </children>
                  </HBox>
               </children>
            </VBox>
            <VBox fx:id="categoryBox">
               <children>
                  <Label text="CATEGORY" />
                  <ComboBox fx:id="categoryFilter" prefHeight="30.0" promptText="CATEGORY" />
               </children>
            </VBox>
            <VBox fx:id="dateBox">
               <children>
                  <Label text="TRANSACTION DATE" />
                  <HBox alignment="CENTER_LEFT" spacing="5.0">
                     <children>
            				<DatePicker fx:id="startDate" prefHeight="30.0" prefWidth="120.0" promptText="From" />
                        <Label text="-">
                           <font>
                              <Font name="Arial Black" size="14.0" />
                           </font>
                        </Label>
            				<DatePicker fx:id="endDate" prefHeight="30.0" prefWidth="120.0" promptText="To" />
                     </children>
                  </HBox>
               </children>
            </VBox>
            <Button fx:id="clearBtn" mnemonicParsing="false" onAction="#clearFilters" text="RESET FILTERS">
         <padding>
            <Insets bottom="10.0" left="15.0" right="15.0" top="10.0" />
         </padding></Button>
   </children>
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
</FlowPane>

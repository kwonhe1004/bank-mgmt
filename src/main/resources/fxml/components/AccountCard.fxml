<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="10.0" styleClass="container-border" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="khe.banking.controllers.components.AccountCardController">
   <padding>
      <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
   </padding>
   <children>
      <HBox alignment="CENTER" spacing="10.0" VBox.vgrow="ALWAYS">
         <children>
            <VBox alignment="CENTER" spacing="5.0">
               <children>
                  <Label fx:id="nicknameLabel" styleClass="card-title" text="Nickname" />
                  <Label fx:id="typeLabel" styleClass="card-subtitle" text="Type" />
               </children>
            </VBox>
         </children>
      </HBox>
      <Label fx:id="balanceLabel" styleClass="card-heading" text="Balance" VBox.vgrow="ALWAYS" />
      <Label fx:id="statusLabel" styleClass="card-heading" text="Status" VBox.vgrow="ALWAYS" />
      <Button mnemonicParsing="false" onAction="#showDetails" text="View Transactions" VBox.vgrow="ALWAYS" />
   </children>
</VBox>

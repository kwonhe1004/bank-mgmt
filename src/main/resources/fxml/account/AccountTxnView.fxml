<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="780.0" prefWidth="880.0" spacing="20.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="khe.banking.controllers.account.AccountTxnController">
   <children>
      <HBox alignment="CENTER_LEFT" spacing="15.0">
         <children>
            <Button mnemonicParsing="false" onAction="#goBack" text="← Back" />
            <Label fx:id="titleLabel" text="Label" />
         </children>
      </HBox>
      <HBox spacing="10.0">
         <children>
            <Button mnemonicParsing="false" text="Button" />
            <TextField />
            <DatePicker />
            <DatePicker />
         </children>
      </HBox>
      <TableView fx:id="txnTable">
        <columns>
          <TableColumn fx:id="nameCol" prefWidth="75.0" text="Name" />
            <TableColumn fx:id="amountCol" prefWidth="75.0" text="Amount" />
          <TableColumn fx:id="typeCol" prefWidth="75.0" text="Type" />
            <TableColumn fx:id="categoryCol" prefWidth="75.0" text="Category" />
            <TableColumn fx:id="dateCol" prefWidth="75.0" text="Date" />
            
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
   </children>
   <padding>
      <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
   </padding>
</VBox>

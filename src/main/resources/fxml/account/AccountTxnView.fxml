<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="780.0" prefWidth="880.0" spacing="20.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="khe.banking.controllers.account.AccountTxnController">
   <children>
      <ToggleButton fx:id="detailsTg" mnemonicParsing="false" style="-fx-background-color: transparent;">
         <graphic>
            <ImageView fitHeight="20.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../../img/more.png" />
               </image>
            </ImageView>
         </graphic>
      </ToggleButton>
      
      <StackPane fx:id="detailsPane" visible="false">
      	<fx:include fx:id="details" source="../components/AccountDetails.fxml" />
      </StackPane>
      
      <HBox alignment="CENTER" spacing="20.0">
			<children>
            <Button fx:id="deleteBtn" alignment="CENTER" contentDisplay="CENTER" disable="true" mnemonicParsing="false" onAction="#delete" prefHeight="30.0" prefWidth="50.0">
               <graphic>
                  <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../../img/delete.png" />
                     </image>
                  </ImageView>
               </graphic>
            </Button>
            <Button alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" prefHeight="30.0" prefWidth="50.0">
               <graphic>
                  <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../../img/print.png" />
                     </image>
                  </ImageView>
               </graphic>
            </Button>
				<Button alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" onAction="#createNew" prefHeight="30.0" prefWidth="50.0">
					<graphic>
						<ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
							<image>
								<Image url="@../../img/add.png" />
							</image>
						</ImageView>
					</graphic>
				</Button>
            <Pane prefWidth="250.0" />				      				
				<TextField fx:id="searchField" prefHeight="30.0" prefWidth="250.0" promptText="Search transactions..." />
            <ToggleButton fx:id="filterTg" mnemonicParsing="false" prefHeight="30.0" text="ADVANCED FILTERS">
               <graphic>
                  <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../../img/filter.png" />
                     </image>
                  </ImageView>
               </graphic>
            </ToggleButton>
			</children>
		</HBox>
      
      <StackPane fx:id="filterPane" visible="false">      
      	<fx:include fx:id="filters" source="../components/Filters.fxml" />      
      </StackPane>
      <TableView fx:id="txnTable" styleClass="txn-table" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="nameCol" prefWidth="75.0" text="Name" />
            <TableColumn fx:id="amountCol" prefWidth="75.0" text="Amount" />
          <TableColumn fx:id="typeCol" prefWidth="75.0" text="Type" />
            <TableColumn fx:id="categoryCol" prefWidth="75.0" text="Category" />
            <TableColumn fx:id="dateCol" prefWidth="75.0" text="Date" />
            <TableColumn fx:id="notesCol" prefWidth="75.0" text="Notes" />
            <TableColumn fx:id="actionCol" prefWidth="75.0" text="Actions" />
            
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
   </children>
   <padding>
      <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
   </padding>
</VBox>

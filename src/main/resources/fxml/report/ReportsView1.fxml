<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Accordion?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
   <content>
      <VBox spacing="20.0">
         <children>
            <Accordion VBox.vgrow="ALWAYS">
        <panes>
          <TitledPane animated="false" text="Cash Flow: LineChart">
               <content>
                  <TabPane styleClass="analytics-tabs" tabClosingPolicy="UNAVAILABLE">
                  	<tabs>
                  		<Tab text="Weekly Cash Flow">
                                 <content>
                                    <VBox alignment="CENTER" styleClass="chart-card">
                                       <children>
                                          <Label styleClass="chart-card-title" text="Weekly Spending" textAlignment="CENTER" wrapText="true" />
                                          <ChoiceBox fx:id="monthBox" />
                              		<StackPane fx:id="weeklyPane" />
                                       </children>
                                    </VBox>
                                 </content>
                        </Tab>
                        <Tab text="Monthly Cash Flow">
                                 <content>
                                    <VBox alignment="CENTER" styleClass="chart-card">
                                       <children>
                                          <Label styleClass="chart-card-title" text="Monthly Spending" textAlignment="CENTER" wrapText="true" />
                                          <ChoiceBox fx:id="inExBox" />
                                          <StackPane fx:id="monthlyPane" />
            
                                       </children>
                                    </VBox>
                                 </content>
                        </Tab>
                              <Tab text="Yearly Cash Flow">
                                 <content>
                                    <VBox alignment="CENTER" styleClass="chart-card">
                                       <children>
                                          <Label styleClass="chart-card-title" text="Yearly Spending" textAlignment="CENTER" wrapText="true" />
                                          <ChoiceBox fx:id="yearBox" />
                                          <StackPane fx:id="yearlyPane" />
                                       </children>
                                    </VBox>
                                 </content>
                              </Tab>
                       </tabs>
                      </TabPane>
               </content>
            </TitledPane>
                  <TitledPane animated="false" text="Category: PieChart">
                     <content>
                        <VBox alignment="CENTER">
                           <children>
                              <HBox alignment="CENTER" spacing="20.0">
                                 <children>
                                    <ChoiceBox fx:id="pieType" />
                                    <ChoiceBox fx:id="pieMonth" />
                                    <ChoiceBox fx:id="pieYear" />
                                 </children>
                                 <padding>
                                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                                 </padding>
                              </HBox>
                            <TabPane styleClass="analytics-tabs" tabClosingPolicy="UNAVAILABLE">
                            	<tabs>
                            		<Tab text="Expenses By Category">
                                       <content>
                                          <StackPane fx:id="expensePane" styleClass="chart-card" />
                                       </content>
                            		</Tab>
                                  <Tab text="Income By Category">
                                       <content>
                                          <StackPane fx:id="incomePane" styleClass="chart-card" />
                                       </content>
                                  </Tab>
                               </tabs>
                             </TabPane>
                           </children>
                        </VBox>
                     </content>
                  </TitledPane>
        </panes>
      </Accordion>
            
         </children>
         <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
      </VBox>
   </content>
</ScrollPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<VBox prefHeight="780.0" prefWidth="880.0" spacing="20.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/26" fx:controller="khe.banking.controllers.report.ReportsController21">
   <padding>
      <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
   </padding>
   <children>
      <Label text="FINANCIAL REPORTS">
         <font>
            <Font size="32.0" />
         </font>
      </Label>
      <HBox spacing="15.0">
         <children>
            <VBox>
               <children>
                  <Label text="Income" />
                  <Label text="\$0.00" />
               </children>
            </VBox>
            <VBox>
               <children>
                  <Label text="Expense" />
                  <Label text="\$0.00" />
               </children>
            </VBox>
            <VBox>
               <children>
                  <Label text="Net Balance" />
                  <Label text="\$0.00" />
               </children>
            </VBox>
         </children>
      </HBox>
      <HBox spacing="10.0">
         <children>
            <DatePicker fx:id="startDate" />
            <DatePicker fx:id="endDate" />
            <Button mnemonicParsing="false" text="Generate" />
            <Button mnemonicParsing="false" text="Export CSV" />
            <Button mnemonicParsing="false" text="Export PDF" />
         </children>
      </HBox>
      <TableView fx:id="reportTable" prefHeight="200.0" prefWidth="200.0">
        <columns>
          <TableColumn fx:id="monthCol" prefWidth="150.0" text="Month" />
            <TableColumn fx:id="incomeCol" prefWidth="150.0" text="Income" />
            <TableColumn fx:id="expenseCol" prefWidth="150.0" text="Expense" />
            <TableColumn fx:id="netCol" prefWidth="150.0" text="Net" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
   </children>
</VBox>
